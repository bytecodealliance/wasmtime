;; (x ^ y) & ((y ^ z) ^ x) --> (x ^ y) & ~z
function %test_band_bxor_bxor_bnot(i32, i32, i32) -> i32 fast {
block0(v0: i32, v1: i32, v2: i32):
    v3 = bxor v0, v1
    v4 = bxor v1, v2
    v5 = bxor v4, v0
    v6 = band v3, v5
    return v6
}

