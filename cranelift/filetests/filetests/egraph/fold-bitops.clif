;; (bor ty (band ty x z) (band ty y z)) -> (band ty (bor ty x y) z)
function %test_bor_band_band(i32, i32, i32) -> i32 fast {
block0(v0: i32, v1: i32, v2: i32):
    v3 = band v0, v2
    v4 = band v1, v2
    v5 = bor v3, v4
    return v5
}

