;; (rule (simplify (bor ty (bor ty x y) y)) (bor ty x y))
function %simplify_bor_xyy(i32, i32) -> i32 {
block0(v0: i32, v1: i32):
    v2 = bor v0, v1
    v3 = bor v2, v1
    return v3
}

