test optimize precise-output
set opt_level=speed
target x86_64

;; (rule (simplify (bor ty x (bor ty x y))) (bor ty x y))
function %simplify_bor_xxy(i32, i32) -> i32 {
block0(v0: i32, v1: i32):
    v2 = bor v0, v1
    v3 = bor v0, v2
    return v3
}

