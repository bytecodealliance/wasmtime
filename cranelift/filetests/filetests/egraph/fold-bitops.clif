;; ((x & ~y) - (x & y)) --> ((x ^ y) - y)
function %test_isub_band_band_bnot(i32, i32) -> i32 fast {
block0(v0: i32, v1: i32):
    v2 = bnot v1
    v3 = band v0, v2
    v4 = band v0, v1
    v5 = isub v3, v4
    return v5
}

