;; (~x & y) ^ z --> (x & y) ^ (z ^ y)
function %test_bxor_band_bnot_general(i32, i32, i32) -> i32 fast {
block0(v0: i32, v1: i32, v2: i32):
    v3 = bnot v0
    v4 = band v3, v1
    v5 = bxor v4, v2
    return v5
}

