;; (band ty (bor ty x z) (bor ty y z)) -> (bor ty (band ty x y) z)
function %test_band_bor_bor(i32, i32, i32) -> i32 fast {
block0(v0: i32, v1: i32, v2: i32):
    v3 = bor v0, v2
    v4 = bor v1, v2
    v5 = band v3, v4
    return v5
}

