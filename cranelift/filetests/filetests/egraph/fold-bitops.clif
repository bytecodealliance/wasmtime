function %test_bxor_bor_bnot_bxor(i32, i32) -> i32 fast {
block0(v0: i32, v1: i32):
    v2 = bnot v0
    v3 = bor v2, v1
    v4 = bxor v0, v1
    v5 = bxor v3, v4
    return v5
}

