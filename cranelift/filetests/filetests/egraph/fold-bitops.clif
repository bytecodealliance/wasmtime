;     return v8
; }

;; (x & ~y) | (x ^ y) --> (x ^ y)
function %test_bor_band_bnot_bxor_absorb(i32, i32) -> i32 fast {
block0(v0: i32, v1: i32):
    v2 = bnot v1
    v3 = band v0, v2
    v4 = bxor v0, v1
    v5 = bor v3, v4
    return v5
}

; function %test_bor_band_bnot_bxor_absorb(i32, i32) -> i32 fast {
; block0(v0: i32, v1: i32):
;     v4 = bxor v0, v1
;     return v4
; }

;; (x & ~y) ^ ~x --> ~(x & y)
function %test_bxor_band_bnot_to_bnot_band(i32, i32) -> i32 fast {
block0(v0: i32, v1: i32):
    v2 = bnot v1
    v3 = band v0, v2
    v4 = bnot v0
    v5 = bxor v3, v4
    return v5
}

