;; (x & ~y) == ~y --> (x | y) == -1
function %test_eq_band_bnot_fullmask(i32, i32) -> i8 fast {
block0(v0: i32, v1: i32):
    v2 = bnot v1
    v3 = band v0, v2
    v4 = icmp eq v3, v2
    return v4
}

