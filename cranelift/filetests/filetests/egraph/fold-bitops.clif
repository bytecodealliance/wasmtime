; }

;; (rule (simplify (bor ty y (bor ty x y))) (bor ty x y))
function %simplify_bor_yxy(i32, i32) -> i32 {
block0(v0: i32, v1: i32):
    v3 = bor v0, v1
    v4 = bor v1, v3
    return v4
}

; function %simplify_bor_yxy(i32, i32) -> i32 fast {
