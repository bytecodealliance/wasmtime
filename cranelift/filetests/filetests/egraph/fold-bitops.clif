;; (x | y) | (x ^ y) --> (x | y)
function %test_bor_bor_bxor_same(i32, i32) -> i32 fast {
block0(v0: i32, v1: i32):
    v2 = bor v0, v1
    v3 = bxor v0, v1
    v4 = bor v2, v3
    return v4
}

