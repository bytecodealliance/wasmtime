;; (bor ty (bnot ty x) (bnot ty y)) -> (bnot ty (band ty x y))
function %test_bor_bnot_bnot(i32, i32) -> i32 fast {
block0(v0: i32, v1: i32):
    v2 = bnot v0
    v3 = bnot v1
    v4 = bor v2, v3
    return v4
}

