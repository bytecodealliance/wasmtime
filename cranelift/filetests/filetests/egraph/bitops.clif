;; (eq ty (bxor cty x z) (bxor cty y z)) -> (eq ty x y)
function %simplify_icmp_eq_bxor_shared_rhs(i32, i32, i32) -> i8 fast {
block0(v0: i32, v1: i32, v2: i32):
    v3 = bxor v0, v2
    v4 = bxor v1, v2
    v5 = icmp eq v3, v4
    return v5
}

