;; (x & y) & x == x & y
;; (x & y) & y == x & y
;; x & (x & y) == x & y
;; y & (x & y) == x & y
function %test_and_and1(i32, i32) -> i32 {
block0(v0: i32, v1: i32):
    v2 = band v0, v1
    v3 = band v2, v0
    return v3
    ; check: v2 = band v0, v1
    ; check: return v2
}

function %test_and_and2(i32, i32) -> i32 {
block0(v0: i32, v1: i32):
    v2 = band v0, v1
    v3 = band v0, v2
    return v3
    ; check: v2 = band v0, v1
    ; check: return v2
}

function %test_and_and3(i32, i32) -> i32 {
block0(v0: i32, v1: i32):
    v2 = band v1, v0
    v3 = band v0, v2
    return v3
    ; check: v2 = band v1, v0
    ; check: return v2
}

function %test_and_and4(i32, i32) -> i32 {
block0(v0: i32, v1: i32):
    v2 = band v1, v0
    v3 = band v2, v0
    return v3
    ; check: v2 = band v1, v0
    ; check: return v2
}

;; (bor ty (bxor ty (bxor ty x y) z) x) -> (bor ty (bxor ty y z) x)
function %test_bor_bxor_bxor_x(i32, i32, i32) -> i32 fast {
block0(v0: i32, v1: i32, v2: i32):
    v3 = bxor v0, v1
    v4 = bxor v3, v2
    v5 = bor v4, v0
    return v5
}

