function %test_bxor_band_bxor_i64(i64, i64) -> i64 {
block0(v0: i64, v1: i64):
    v2 = band v0, v1
    v3 = bxor v0, v1
    v4 = bxor v2, v3
    return v4
    ; check: v5 = bor v0, v1
    ; check: return v5
}

