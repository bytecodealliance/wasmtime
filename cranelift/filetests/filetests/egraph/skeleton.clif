test optimize precise-output
set opt_level=speed
target x86_64

function %remove_trapz() {
block0:
    v0 = iconst.i32 1
    trapz v0, user42
    return
}

; function %remove_trapz() fast {
; block0:
;     return
; }

function %remove_trapnz() {
block0:
    v0 = iconst.i32 0
    trapnz v0, user42
    return
}

