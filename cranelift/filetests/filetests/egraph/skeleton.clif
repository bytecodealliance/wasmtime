;     jump block2
;
; block2:
;     v2 = iconst.i32 20
;     return v2  ; v2 = 20
; }

function %br_table_out_of_bounds() -> i32 {
block0:
    v0 = iconst.i32 99
    br_table v0, block3, [block1, block2]
block1:
    v1 = iconst.i32 10
    return v1
block2:
    v2 = iconst.i32 20
    return v2
block3:
    v3 = iconst.i32 -1
    return v3
}

