function %uadd_overflow_trap_of_uextends(i32, i32) -> i64 {
block0(v0: i32, v1: i32):
    v2 = uextend.i64 v0
    v3 = uextend.i64 v1
    v4 = uadd_overflow_trap v2, v3, user42
    return v4
}

