function %select_eq_xy_xy_to_y(i32, i32) -> i32 fast {
block0(v0: i32, v1: i32):
    v2 = icmp eq v0, v1
    v3 = select v2, v0, v1
    return v3
}

; function %select_eq_xy_xy_to_y(i32, i32) -> i32 fast {
; block0(v0: i32, v1: i32):
;     return v1
; }

;; (x | (y != z)) ? y : z  ==> y
function %select_bor_ne_to_y(i8, i8, i8) -> i8 fast {
block0(v0: i8, v1: i8, v2: i8):
    v3 = icmp ne v1, v2
    v4 = bor v0, v3
    v5 = select v4, v1, v2
    return v5
}

; function %select_bor_ne_to_y(i8, i8, i8) -> i8 fast {
; block0(v0: i8, v1: i8, v2: i8):
;     return v1
; }

;; (x == y) ? x : (x | y)  ==> (x | y)
function %select_eq_xy_x_borxy_to_borxy(i32, i32) -> i32 fast {
block0(v0: i32, v1: i32):
    v2 = icmp eq v0, v1
    v3 = bor v0, v1
    v4 = select v2, v0, v3
    return v4
}

; function %select_eq_xy_x_borxy_to_borxy(i32, i32) -> i32 fast {
; block0(v0: i32, v1: i32):
;     v3 = bor v0, v1
;     return v3
; }

;; (x != y) ? (x & y) : y  ==> (x & y)
function %select_ne_xy_bandxy_y_to_bandxy(i32, i32) -> i32 fast {
block0(v0: i32, v1: i32):
    v2 = icmp ne v0, v1
    v3 = band v0, v1
    v4 = select v2, v3, v1
    return v4
}

