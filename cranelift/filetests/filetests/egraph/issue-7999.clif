test optimize
set opt_level=speed
target x86_64

function u0:11(i8) -> i8 system_v {
block0(v0: i8):
    v1 = uextend.i64 v0
    v11 = iconst.i64 256
    v2 = imul v1, v11
    v3 = ireduce.i8 v2
    return v3

    ;; This function should get optimized down to simply returning zero:

    ; check: return v17  ; v17 = 0
}
