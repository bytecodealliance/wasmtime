;     v3 = isub v0, v2
;     return v3
; }

;; (x + (y + (z - x))) --> (y + z)
function %test_iadd_iadd_isub_cancel(i32, i32, i32) -> i32 fast {
block0(v0: i32, v1: i32, v2: i32):
    v3 = isub v2, v0
    v4 = iadd v1, v3
    v5 = iadd v0, v4
    return v5
}

