function %fold_isub_iadd_band_to_bor_i32(i32, i32) -> i32 {
block0(v0: i32, v1: i32):
    v2 = iadd v0, v1
    v3 = band v0, v1
    v4 = isub v2, v3
    return v4
}

; function %fold_isub_iadd_band_to_bor_i32(i32, i32) -> i32 fast {
; block0(v0: i32, v1: i32):
;     v6 = bor v1, v0
