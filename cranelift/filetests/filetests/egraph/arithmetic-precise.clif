;; -((-y) * x) --> x * y
function %test_ineg_imul_ineg_lhs(i32, i32) -> i32 fast {
block0(v0: i32, v1: i32):
    v2 = ineg v1
    v3 = imul v2, v0
    v4 = ineg v3
    return v4
}

