;; (eq ty (iadd cty x y) (iadd cty y x)) -> 1
function %simplify_icmp_eq_iadd_commute(i32, i32) -> i8 fast {
block0(v0: i32, v1: i32):
    v2 = iadd v0, v1
    v3 = iadd v1, v0
    v4 = icmp eq v2, v3
    return v4
}

; function %simplify_icmp_eq_iadd_commute(i32, i32) -> i8 fast {
; block0(v0: i32, v1: i32):
;     v6 = iconst.i8 1
;     return v6  ; v6 = 1
; }

;; (x - y) != x --> y != 0
function %simplify_icmp_ne_isub_x(i32, i32) -> i8 fast {
block0(v0: i32, v1: i32):
    v2 = isub v0, v1
    v3 = icmp ne v2, v0
    return v3
}

