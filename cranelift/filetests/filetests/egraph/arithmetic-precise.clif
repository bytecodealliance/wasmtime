;; ((x - y) - (x - z)) --> (z - y)
function %test_isub_isub_isub_swap_cancel(i32, i32, i32) -> i32 fast {
block0(v0: i32, v1: i32, v2: i32):
    v3 = isub v0, v1
    v4 = isub v0, v2
    v5 = isub v3, v4
    return v5
}

