;; (x | y) - (x & y)  ==>  (x ^ y)
function %test_isub_bor_band_to_bxor(i32, i32) -> i32 fast {
block0(v0: i32, v1: i32):
    v2 = bor v0, v1
    v3 = band v0, v1
    v4 = isub v2, v3
    return v4
}

