;; ireduce(sextend(x) + uextend(y)) --> x + y
function %test_ireduce_iadd_extends(i8, i8) -> i8 fast {
block0(v0: i8, v1: i8):
    v2 = sextend.i16 v0
    v3 = uextend.i16 v1
    v4 = iadd v2, v3
    v5 = ireduce.i8 v4
    return v5
}

