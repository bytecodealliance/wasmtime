;; umin(x, y) + umax(x, y) --> x + y
function %test_iadd_umin_umax(i32, i32) -> i32 fast {
block0(v0: i32, v1: i32):
    v2 = umin v0, v1
    v3 = umax v0, v1
    v4 = iadd v2, v3
    return v4
}

