;; ((x + y) - (x + z)) --> (y - z)
function %test_isub_iadd_iadd_cancel(i32, i32, i32) -> i32 fast {
block0(v0: i32, v1: i32, v2: i32):
    v3 = iadd v0, v1
    v4 = iadd v0, v2
    v5 = isub v3, v4
    return v5
}

; function %test_isub_iadd_iadd_cancel(i32, i32, i32) -> i32 fast {
