test optimize precise-output
set opt_level=speed
target x86_64

function %fold_iadd_iadd_ineg_i32(i32, i32) -> i32 {
block0(v0: i32, v1: i32):
    v2 = iadd v0, v1
    v3 = ineg v1
    v4 = iadd v2, v3
    return v4
}

