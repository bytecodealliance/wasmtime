;; -x == -y --> x == y
function %test_eq_ineg_ineg(i32, i32) -> i8 fast {
block0(v0: i32, v1: i32):
    v2 = ineg v0
    v3 = ineg v1
    v4 = icmp eq v2, v3
    return v4
}

