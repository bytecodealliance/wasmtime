;; ((x - y) + (y + z)) --> (x + z)
function %test_iadd_isub_iadd_cancel(i32, i32, i32) -> i32 fast {
block0(v0: i32, v1: i32, v2: i32):
    v3 = isub v0, v1
    v4 = iadd v1, v2
    v5 = iadd v3, v4
    return v5
}

