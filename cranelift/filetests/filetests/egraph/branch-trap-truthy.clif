;; brif (sextend x) -> brif x
function %brif_sextend(i8) -> i32 {
block0(v0: i8):
    v1 = sextend.i32 v0
    brif v1, block1, block2

block1:
    v2 = iconst.i32 100
    return v2

block2:
    v3 = iconst.i32 200
    return v3
}

