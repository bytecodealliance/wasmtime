; block0(v0: i32):
;     v4 = iconst.i32 0
;     v5 = icmp sge v0, v4  ; v4 = 0
;     brif v5, block1, block2
;
; block1:
;     v2 = iconst.i32 100
;     return v2  ; v2 = 100
;
; block2:
;     v3 = iconst.i32 200
;     return v3  ; v3 = 200
; }

;; Same for i64.
function %brif_ctz_i64(i64) -> i32 {
block0(v0: i64):
    v1 = ctz v0
    brif v1, block1, block2

block1:
    v2 = iconst.i32 100
    return v2

block2:
    v3 = iconst.i32 200
    return v3
}

