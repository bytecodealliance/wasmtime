test optimize precise-output
set opt_level=speed
target x86_64

; Test branch simplifications and irreducible control flow.

function %f() {
block0:
    v0 = iconst.i8 0
    brif v0, block2, block1

block1:
    jump block2

block2:
    jump block1
}

