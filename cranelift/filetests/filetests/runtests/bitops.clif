; run: %test_bor_band_bnot_bxor(1, 1) == 0xffffffff
; run: %test_bor_band_bnot_bxor(0, 1) == 0xfffffffe
; run: %test_bor_band_bnot_bxor(2, 1) == 0xfffffffc

