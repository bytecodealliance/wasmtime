function %icmp_imm_eq_i8(i8) -> i8 {
block0(v0: i8):
    v2 = iconst.i8 0x44
    v1 = icmp eq v0, v2
    return v1
}
; run: %icmp_imm_eq_i8(0) == 0
; run: %icmp_imm_eq_i8(-1) == 0
; run: %icmp_imm_eq_i8(0x44) == 1

function %icmp_neg_eq_i8(i8) -> i8 {
block0(v0: i8):
    v2 = iconst.i8 0xf4
    v1 = icmp eq v0, v2
    return v1
}
; run: %icmp_neg_eq_i8(0) == 0
; run: %icmp_neg_eq_i8(-1) == 0
; run: %icmp_neg_eq_i8(0xf4) == 1

