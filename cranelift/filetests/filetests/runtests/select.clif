function %select_eq_x1_yminus1_yminusx_to_yminusx_rt(i32, i32) -> i32 fast {
block0(v0: i32, v1: i32):
  v2 = iconst.i32 1
  v3 = icmp eq v0, v2
  v4 = isub v1, v2
  v5 = isub v1, v0
  v6 = select v3, v4, v5
  return v6
}
