function %simplify_iadd_select_const_i32(i8) -> i32 fast {
block0(v0: i8):
    v1 = iconst.i32 5
    v2 = iconst.i32 10
    v3 = select v0, v1, v2
    v4 = iconst.i32 3
    v5 = iadd v3, v4
    return v5
}

; run: %simplify_iadd_select_const_i32(0) == 13
; run: %simplify_iadd_select_const_i32(1) == 8

;; should be optimized to x > y
function %simplify_select_slt_ne_i32(i32, i32) -> i8 fast {
block0(v0: i32, v1: i32):
    v2 = icmp slt v0, v1
    v3 = select v2, v0, v1
    v4 = icmp ne v3, v0
    return v4
}

; run: %simplify_select_slt_ne_i32(92, 42) == 1
; run: %simplify_select_slt_ne_i32(7, -8) == 1
; run: %simplify_select_slt_ne_i32(-79, 42) == 0
; run: %simplify_select_slt_ne_i32(-1111111, 42) == 0

;; should be optimized to x > y (unsigned)
function %simplify_select_ult_ne_i64(i64, i64) -> i8 fast {
block0(v0: i64, v1: i64):
    v2 = icmp ult v0, v1
    v3 = select v2, v0, v1
    v4 = icmp ne v3, v0
    return v4
}

; run: %simplify_select_ult_ne_i64(8, 42) == 0
; run: %simplify_select_ult_ne_i64(7, 9) == 0
; run: %simplify_select_ult_ne_i64(3, 1) == 1
; run: %simplify_select_ult_ne_i64(-1, 42) == 1

function %test_sgt_select_slt_min(i32, i32) -> i8 fast {
block0(v0: i32, v1: i32):
    v2 = icmp slt v1, v0  ; (slt y, x)
    v3 = select v2, v1, v0 ; select( (y <_s x), y, x) -> smin(y, x)
    v4 = icmp sgt v3, v0   ; sgt( min(y, x), x )
    return v4
}

; run: %test_sgt_select_slt_min(42, 444) == 0

function %test_ugt_select_ult_min(i32, i32) -> i8 fast {
block0(v0: i32, v1: i32):
    v2 = icmp ult v1, v0  ; (slt y, x)
    v3 = select v2, v1, v0 ; select( (y <_s x), y, x) -> umin(y, x)
    v4 = icmp ugt v3, v0   ; sgt( min(y, x), x )
    return v4
}

; run: %test_ugt_select_ult_min(234234, 5544) == 0

