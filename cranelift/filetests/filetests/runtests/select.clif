function %select_eq_eq_to_eq_select_rt(i8, i32, i32) -> i8 fast {
block0(v0: i8, v1: i32, v2: i32):
  v3 = icmp eq v2, v1
  v4 = iconst.i32 7
  v5 = icmp eq v4, v1
  v6 = select v0, v3, v5
