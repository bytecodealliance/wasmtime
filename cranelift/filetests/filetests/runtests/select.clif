function %select_x_one_borxy_to_select_x_one_y_rt(i8, i8) -> i8 fast {
block0(v0: i8, v1: i8):
  v2 = iconst.i8 1
  v3 = bor v0, v1
  v4 = select v0, v2, v3
  return v4
}
