test compile precise-output
set unwind_info=false
target aarch64

function %f(i64, i64) -> i64 {
    sig0 = (i64) -> i64
block0(v0: i64, v1: i64):
    v2 = call_indirect.i64 sig0, v1(v0)
    return v2
}

; VCode:
;   str lr, [sp, #-16]!
; block0:
;   blr x1
;   ldr lr, [sp], #16
;   ret
;
; Disassembled:
; block0: ; offset 0x0
;   str x30, [sp, #-0x10]!
; block1: ; offset 0x4
;   blr x1
;   ldr x30, [sp], #0x10
;   ret

