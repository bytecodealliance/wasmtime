test compile precise-output
set enable_multi_ret_implicit_sret
set unwind_info=false
target riscv64 has_v


function %iadd_const_i8x16(i8x16) -> i8x16 {
block0(v0: i8x16):
    v2 = vconst.i8x16 0x01010101_01010101_01010101_01010101
    v3 = iadd v0, v2

    v4 = vconst.i8x16 0x00010001_00010001_00010001_00010001
    v5 = iadd v3, v4

    v6 = vconst.i8x16 0x00000001_00000001_00000001_00000001
    v7 = iadd v5, v6

    v8 = vconst.i8x16 0x00000000_00000001_00000000_00000001
    v9 = iadd v7, v8

    return v9
}

