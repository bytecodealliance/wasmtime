test compile precise-output
target x86_64 sse41

function %bitselect_f32_loads(i64, i64, i64) -> f32 {
block0(v0: i64, v1: i64, v2: i64):
    v3 = load.f32 v0
    v4 = load.f32 v1
    v5 = load.f32 v2
    v6 = bitselect v3, v4, v5
    return v6
}

