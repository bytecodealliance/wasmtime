function %bitselect_f64_loads(i64, i64, i64) -> f64 {
block0(v0: i64, v1: i64, v2: i64):
    v3 = load.f64 v0
    v4 = load.f64 v1
    v5 = load.f64 v2
    v6 = bitselect v3, v4, v5
    return v6
}

