test compile precise-output
set opt_level=speed
target x86_64


function %i32_shl_sshr_8_to_ireduce(i32) -> i32 {
block0(v0: i32):
    v3 = iconst.i32 24
    v1 = ishl v0, v3
    v4 = iconst.i32 24
    v2 = sshr v1, v4
    return v2
}

