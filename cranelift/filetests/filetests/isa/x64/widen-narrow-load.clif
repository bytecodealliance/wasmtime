test compile precise-output
set opt_level=speed
target x86_64 has_bmi1

function %andn_i8_load(i64, i8) -> i8 {
block0(v0: i64, v1: i8):
    v2 = load.i8 v0
    v3 = band_not v2, v1
    return v3
}

; VCode:
;   pushq %rbp
;   movq %rsp, %rbp
; block0:
;   movzbq (%rdi), %rdi
;   andnl %edi, %esi, %eax
;   movq %rbp, %rsp
;   popq %rbp
;   retq
;
; Disassembled:
; block0: ; offset 0x0
;   pushq %rbp
;   movq %rsp, %rbp
; block1: ; offset 0x4
;   movzbq (%rdi), %rdi ; trap: heap_oob
;   andnl %edi, %esi, %eax
;   movq %rbp, %rsp
;   popq %rbp
;   retq

