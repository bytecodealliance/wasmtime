;; ---- `select` via `cmove` ---------------------------------------------

;; The consequent (`a` in `select cond a b`) flows to the `c` slot of `cmove`.

function %select_i8_load(i32, i64, i8) -> i8 {
block0(v0: i32, v1: i64, v2: i8):
    v3 = load.i8 v1
    v4 = select.i8 v0, v3, v2
    return v4
}

