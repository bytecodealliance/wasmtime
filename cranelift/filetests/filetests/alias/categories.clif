test alias-analysis
set opt_level=speed
target aarch64

;; Check that aliasing properly respects the last store in each
;; "category" separately.

function %f0(i64, i64) -> i32, i32 {

    region0 = 0 "heap"
    region1 = 1 "table"

block0(v0: i64, v1: i64):
    v2 = iconst.i32 42
    v3 = iconst.i32 43
    store.i32 region0 v2, v0+8
    store.i32 region1 v3, v1+8

    v4 = load.i32 region0 v0+8
    v5 = load.i32 region1 v1+8
    ; check: v4 -> v2
    ; check: v5 -> v3

    return v4, v5
}
