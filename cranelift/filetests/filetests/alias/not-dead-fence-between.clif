function %atomic_store_between(i64, i32, i32, i32) {
    region0 = 0 "R0"
block0(v0: i64, v1: i32, v2: i32, v3: i32):
    store notrap aligned region0 v1, v0
    atomic_store.i32 v3, v0
    store notrap aligned region0 v2, v0
    return
}

